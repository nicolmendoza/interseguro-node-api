{
  "name": "interseguro-node-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Express API that calculates statistics for matrices returned by the Go API.",
  "main": "dist/src/transport/http/server.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "tsx watch src/transport/http/server.ts",
    "build": "tsc",
    "start": "node dist/src/transport/http/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^30.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
